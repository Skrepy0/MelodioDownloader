{
  "name": "MelodioDownloader",
  "version": "1.0.0",
  "main": "dist-electron/main/index.js",
  "description": "一个基于musicdl与electron的音乐下载器",
  "author": "Skrepy",
  "license": "Apache-2.0",
  "private": true,
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue"
  ],
  "type": "module",
  "scripts": {
    "predev": "pnpm run pack-py",
    "prebuild": "pnpm run pack-py",
    "pack-py": "node scripts/pack-python.cjs",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "preview": "vite preview",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-electron": "^1.0.1",
    "vite-plugin-electron-renderer": "^1.0.0",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  },
  "dependencies": {
    "prettier": "^3.9.5"
  }
}
